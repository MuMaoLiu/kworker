#!/bin/bash
# KHSL Git hooks
# Pre-commit hook for code formatting and basic checks

# Check if we should skip hooks
if [ "$SKIP_HOOKS" = "1" ]; then
    exit 0
fi

# Get the root directory of the git repository
GIT_ROOT=$(git rev-parse --show-toplevel)
cd "$GIT_ROOT" || exit 1

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running KHSL pre-commit hooks...${NC}"

# Function to check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Check for C/C++ files that need formatting
CC_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|cpp|h|hpp)$' || true)

if [ -n "$CC_FILES" ]; then
    if command_exists clang-format; then
        echo -e "${YELLOW}Checking C/C++ code formatting...${NC}"
        
        # Check if files need formatting
        NEEDS_FORMATTING=false
        for file in $CC_FILES; do
            if [ -f "$file" ]; then
                if ! clang-format --dry-run --Werror "$file" >/dev/null 2>&1; then
                    echo -e "${RED}Code formatting issues found in: $file${NC}"
                    NEEDS_FORMATTING=true
                fi
            fi
        done
        
        if [ "$NEEDS_FORMATTING" = true ]; then
            echo -e "${RED}Please run 'make format' to fix formatting issues${NC}"
            exit 1
        fi
        
        echo -e "${GREEN}C/C++ code formatting check passed${NC}"
    else
        echo -e "${YELLOW}clang-format not found, skipping format check${NC}"
    fi
fi

# Run static analysis if cppcheck is available
if command_exists cppcheck; then
    echo -e "${YELLOW}Running static analysis...${NC}"
    
    # Run cppcheck on C/C++ files
    if [ -n "$CC_FILES" ]; then
        cppcheck --enable=warning,style,performance,portability \
                 --suppress=missingIncludeSystem \
                 --error-exitcode=1 \
                 --inline-suppr \
                 $CC_FILES
        
        if [ $? -ne 0 ]; then
            echo -e "${RED}Static analysis found issues${NC}"
            exit 1
        fi
        
        echo -e "${GREEN}Static analysis passed${NC}"
    fi
else
    echo -e "${YELLOW}cppcheck not found, skipping static analysis${NC}"
fi

# Check for trailing whitespace
echo -e "${YELLOW}Checking for trailing whitespace...${NC}"
TRAILING_WHITESPACE=$(git diff --cached --check || true)

if [ -n "$TRAILING_WHITESPACE" ]; then
    echo -e "${RED}Trailing whitespace found:${NC}"
    echo "$TRAILING_WHITESPACE"
    exit 1
fi

echo -e "${GREEN}No trailing whitespace found${NC}"

# Check for merge conflict markers
echo -e "${YELLOW}Checking for merge conflict markers...${NC}"
CONFLICT_MARKERS=$(git diff --cached --name-only | xargs grep -l '^<<<<<<< \|^=======\|^>>>>>>> ' 2>/dev/null || true)

if [ -n "$CONFLICT_MARKERS" ]; then
    echo -e "${RED}Merge conflict markers found in:${NC}"
    echo "$CONFLICT_MARKERS"
    exit 1
fi

echo -e "${GREEN}No merge conflict markers found${NC}"

# Check for large files (>10MB)
echo -e "${YELLOW}Checking for large files...${NC}"
LARGE_FILES=$(git diff --cached --name-only --diff-filter=A | while read file; do
    if [ -f "$file" ]; then
        SIZE=$(stat -c%s "$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null || echo 0)
        if [ "$SIZE" -gt 10485760 ]; then
            echo "$file ($((SIZE/1048576))MB)"
        fi
    fi
done)

if [ -n "$LARGE_FILES" ]; then
    echo -e "${RED}Large files detected (>10MB):${NC}"
    echo "$LARGE_FILES"
    echo -e "${YELLOW}Consider using Git LFS for large files${NC}"
    exit 1
fi

echo -e "${GREEN}No large files detected${NC}"

# Check commit message format (if committing)
if [ "$1" = "commit" ]; then
    COMMIT_MSG_FILE="$2"
    if [ -f "$COMMIT_MSG_FILE" ]; then
        echo -e "${YELLOW}Checking commit message format...${NC}"
        
        # Check if commit message follows conventional format
        FIRST_LINE=$(head -n1 "$COMMIT_MSG_FILE")
        if ! echo "$FIRST_LINE" | grep -qE '^(feat|fix|docs|style|refactor|test|chore)(\(.+\))?: .{1,50}$'; then
            echo -e "${RED}Commit message doesn't follow conventional format${NC}"
            echo -e "${YELLOW}Format: type(scope): description (max 50 chars)${NC}"
            echo -e "${YELLOW}Types: feat, fix, docs, style, refactor, test, chore${NC}"
            exit 1
        fi
        
        echo -e "${GREEN}Commit message format is valid${NC}"
    fi
fi

echo -e "${GREEN}All pre-commit checks passed!${NC}"
exit 0