/dts-v1/;
#include "rk3568.dtsi"
#include "rk3568-u-boot.dtsi"
#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>

/ {
	model = "KHDVK RK3568 Board";
	compatible = "kaihong,khdvk_rk3568_a", "rockchip,rk3568";

	/* Match kernel HDMI DTS: USB2 host PHY + HUB port power for BIOS keyboard */
	vcc5v0_usb: vcc5v0-usb {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_usb";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
	};

	vcc5v0_host: vcc5v0-host-regulator {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_host";
		regulator-boot-on;
		regulator-always-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		vin-supply = <&vcc5v0_usb>;
	};

	adc-keys {
		compatible = "adc-keys";
		io-channels = <&saradc 0>;
		io-channel-names = "buttons";
		keyup-threshold-microvolt = <1800000>;
		u-boot,dm-spl;
		status = "okay";

		volumeup-key {
			u-boot,dm-spl;
			linux,code = <KEY_VOLUMEUP>;
			label = "volume up";
			press-threshold-microvolt = <9>;
		};
	};
};

&gmac0 {
	phy-mode = "rgmii";
	clock_in_out = "output";

	snps,reset-gpio = <&gpio2 RK_PD3 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	/* Reset time is 20ms, 100ms for rtl8211f */
	snps,reset-delays-us = <0 20000 100000>;
	assigned-clocks = <&cru SCLK_GMAC0_RX_TX>, <&cru SCLK_GMAC0>;
	assigned-clock-parents = <&cru SCLK_GMAC0_RGMII_SPEED>;
	assigned-clock-rates = <0>, <125000000>;

	pinctrl-names = "default";
	pinctrl-0 = <&gmac0_miim
		     &gmac0_tx_bus2
		     &gmac0_rx_bus2
		     &gmac0_rgmii_clk
		     &gmac0_rgmii_bus>;

	tx_delay = <0x3c>;
	rx_delay = <0x2f>;

	phy-handle = <&rgmii_phy0>;
	status = "disabled";
};

&gmac1 {
	phy-mode = "rgmii";
	clock_in_out = "output";

	snps,reset-gpio = <&gpio2 RK_PD1 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	/* Reset time is 20ms, 100ms for rtl8211f */
	snps,reset-delays-us = <0 20000 100000>;

	assigned-clocks = <&cru SCLK_GMAC1_RX_TX>, <&cru SCLK_GMAC1>;
	assigned-clock-parents = <&cru SCLK_GMAC1_RGMII_SPEED>;
	assigned-clock-rates = <0>, <125000000>;

	pinctrl-names = "default";
	pinctrl-0 = <&gmac1m1_miim
		     &gmac1m1_tx_bus2
		     &gmac1m1_rx_bus2
		     &gmac1m1_rgmii_clk
		     &gmac1m1_rgmii_bus>;

	tx_delay = <0x4f>;
	rx_delay = <0x26>;

	phy-handle = <&rgmii_phy1>;
	status = "disabled";
};

&mdio0 {
	rgmii_phy0: phy@0 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x0>;
	};
};

&mdio1 {
	rgmii_phy1: phy@0 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0x0>;
	};
};

&crypto {
	status = "okay";
};

&uart2 {
	status = "okay";
};

/*
 * U-Boot: disable USB3 DWC3 (missing maximum-speed on this board).
 * BIOS keyboard uses USB2 host0 only (J98 / u2phy1_otg).
 */
&usbdrd30 {
	status = "disabled";
	/delete-property/ u-boot,dm-pre-reloc;
};

&usbdrd_dwc3 {
	status = "disabled";
	/delete-property/ u-boot,dm-pre-reloc;
};

&usbhost30 {
	status = "disabled";
	/delete-property/ u-boot,dm-pre-reloc;
};

&usbhost_dwc3 {
	status = "disabled";
	/delete-property/ u-boot,dm-pre-reloc;
};

&u2phy0_host {
	phy-supply = <&vcc5v0_host>;
	status = "okay";
};

/* RK3568: usb_host0 (J98) = u2phy1_otg. Do not enable host1 in U-Boot (EHCI timeout). */
&usb2phy1 {
	status = "okay";
};

&u2phy1_otg {
	phy-supply = <&vcc5v0_host>;
	status = "okay";
};

&u2phy1_host {
	status = "disabled";
};

&usb2phy0 {
	status = "okay";
};

&usb_host0_ehci {
	status = "okay";
};

&usb_host0_ohci {
	status = "okay";
};

&usb_host1_ehci {
	status = "disabled";
};

&usb_host1_ohci {
	status = "disabled";
};

/*
 * USB HUB + port power (kernel HDMI DTS: gpio1 PD3 = HUB EN; gpio2 PD0/4/5/6 = J34/J19/J17/J33).
 * gpio-hog: U-Boot fixed-regulator+gpio often fails to bind (-19); hog works at GPIO probe.
 */
&gpio1 {
	usb-hub-en-hog {
		gpio-hog;
		gpios = <RK_PD3 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "usb-hub-en";
	};
};

&gpio2 {
	usb-j34-en-hog {
		gpio-hog;
		gpios = <RK_PD0 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "usb-j34-en";
	};
	usb-j19-en-hog {
		gpio-hog;
		gpios = <RK_PD4 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "usb-j19-en";
	};
	usb-j17-en-hog {
		gpio-hog;
		gpios = <RK_PD5 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "usb-j17-en";
	};
	usb-j33-en-hog {
		gpio-hog;
		gpios = <RK_PD6 GPIO_ACTIVE_HIGH>;
		output-high;
		line-name = "usb-j33-en";
	};
};
